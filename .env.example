# Supabase
# Get these from: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub App
# Get these from: https://github.com/settings/apps/<app-name>
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=        # PEM contents, newlines as \n
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# App
# The public URL of the deployed dashboard (used in PR comment links)
NEXT_PUBLIC_APP_URL=https://app.dep-trust.dev

# CLI (optional override — defaults to NEXT_PUBLIC_APP_URL)
# DEP_TRUST_API_URL=http://localhost:3001
